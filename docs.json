{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mira AI",
  "colors": {
    "primary": "#7C3AED",
    "light": "#A78BFA",
    "dark": "#5B21B6"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/chat",
              "features/images",
              "features/voice",
              "features/video",
              "features/integrations",
              "features/wallet",
              "features/memory"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Telegram",
          "href": "https://t.me/mira",
          "icon": "paper-plane"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/DariaYakovleva/mira-wiki",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Try Mira",
        "href": "https://t.me/mira"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open in Telegram",
      "href": "https://t.me/mira"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/DariaYakovleva/mira-wiki"
    }
  }
}
